<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- App theme for dark mode -->
    <style name="Theme.WifiInsight" parent="android:Theme.Material.Light.NoActionBar" />
    
    <!-- Splash screen theme for dark mode -->
    <style name="Theme.WifiInsight.Starting" parent="Theme.SplashScreen">
        <!-- Window background -->
        <item name="windowSplashScreenBackground">#4A4458</item>
        
        <!-- Animated icon - use our WiFi logo -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_logo_wifi</item>
        
        <!-- Animation duration (max 1000ms according to Android guidelines) -->
        <item name="windowSplashScreenAnimationDuration">300</item>
        
        <!-- Icon background color -->
        <item name="windowSplashScreenIconBackgroundColor">#4A4458</item>
        
        <!-- Post splash screen theme -->
        <item name="postSplashScreenTheme">@style/Theme.WifiInsight</item>
        
        <!-- Status bar and navigation bar -->
        <item name="android:statusBarColor">#4A4458</item>
        <item name="android:navigationBarColor">#4A4458</item>
    </style>
</resources>

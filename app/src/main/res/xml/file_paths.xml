<?xml version="1.0" encoding="utf-8"?>
<!--
   FileProvider paths for sharing exported scan data.
-->
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- External storage (Downloads folder) -->
    <external-path
        name="downloads"
        path="Download/" />
    
    <!-- Cache directory for temporary files -->
    <cache-path
        name="cache"
        path="." />
    
    <!-- External cache -->
    <external-cache-path
        name="external_cache"
        path="." />
</paths>
